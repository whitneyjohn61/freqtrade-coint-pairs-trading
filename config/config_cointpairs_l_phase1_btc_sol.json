{
  "max_open_trades": 2,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.9,
  "fiat_display_currency": "USD",

  "dry_run": true,
  "dry_run_wallet": 10000,

  "cancel_open_orders_on_exit": false,
  "trading_mode": "futures",
  "margin_mode": "isolated",

  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },

  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0,
    "check_depth_of_market": {"enabled": false, "bids_to_ask_delta": 1}
  },

  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },

  "cointpairs": {
    "traded": "BTC/USDT:USDT",
    "anchor": "SOL/USDT:USDT"
  },

  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": ["BTC/USDT:USDT", "SOL/USDT:USDT"],
    "pair_blacklist": [],
    "fee": 0.0005
  },

  "pairlists": [{"method": "StaticPairList"}],

  "freqai": {
    "enabled": false,
    "purge_old_models": true,
    "train_period_days": 60,
    "backtest_period_days": 7,
    "identifier": "cointpairs_fwd_btc_sol_disabled",
    "feature_parameters": {
      "include_timeframes": ["4h"],
      "include_corr_pairlist": ["BTC/USDT:USDT"],
      "label_period_candles": 16,
      "include_shifted_candles": 2,
      "indicator_periods_candles": [10, 20],
      "plot_feature_importances": 0,
      "noise_standard_deviation": 0.02,
      "DI_threshold": 0.45
    },
    "data_split_parameters": {"test_size": 0.25, "shuffle": false},
    "model_training_parameters": {
      "n_estimators": 100,
      "learning_rate": 0.05,
      "max_depth": 6,
      "tree_method": "hist",
      "subsample": 0.8,
      "colsample_bytree": 0.8
    }
  },

  "bot_name": "CointPairsFwd_BtcSol",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {"process_throttle_secs": 5},

  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "CHANGE_ME_JWT_BTC_SOL",
    "CORS_origins": [],
    "username": "freqtrader",
    "password": "CHANGE_ME_UI_PASSWORD"
  }
}
