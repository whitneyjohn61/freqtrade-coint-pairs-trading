# Copy this file to local.env in the same folder (scripts/local.env).
# scripts/local.env is gitignored — never commit it.
#
# Used by droplet_status_from_local.ps1 and droplet_setup_from_local.ps1 (optional overrides).

# --- Droplet IPs ---
FT_V01_HOST=165.227.165.131
FT_V02_HOST=139.59.139.196

# SSH user (optional; default root)
# FT_SSH_USER=root

# droplet_setup_from_local.ps1: target host if you do not pass -DropletHost
# FT_DROPLET_HOST=165.227.165.131
# FT_COMPOSE_PROFILE=v01

# FreqUI API (optional). Username is usually freqtrader; passwords differ per Droplet if you ran generate_api_secrets separately.
# Loaded into env for scripts / future REST helpers — not sent over git.
# FT_UI_USER=freqtrader
# FT_UI_PASSWORD_V01=
# FT_UI_PASSWORD_V02=
